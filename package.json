{
  "name": "web-genealogia",
  "version": "1.0.0",
  "description": "Sitio web de genealogía y memoria familiar",
  "scripts": {
    "build": "node scripts/build.js",
    "translate": "node scripts/translate.js",
    "translate-build": "node scripts/translate.js && node scripts/build.js",
    "delete-post": "node scripts/delete-post.js",
    "list-posts": "node scripts/delete-post.js --list",
    "dev": "node scripts/build.js && python3 -m http.server 8000",
    "serve": "npx serve .",
    "clean": "rm -rf dist/",
    "optimize-personas": "node scripts/optimize-personas.js",
    "deploy": "node scripts/update-and-deploy.js",
    "update": "node scripts/update-and-deploy.js"
  },
  "dependencies": {
    "marked": "^16.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
